<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Заголовок и статус подключения -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/connection"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/ipField"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/ip_hint"
                android:inputType="text"
                android:singleLine="true" />

            <Button
                android:id="@+id/connectButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/connect_manual" />
        </LinearLayout>

        <Button
            android:id="@+id/discoverButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/discover"
            style="?attr/materialButtonOutlinedStyle" />

        <LinearLayout
            android:id="@+id/devicesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_disconnected"
            android:textColor="@color/status_bad"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/pingLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ping_unknown"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDD" />

        <!-- Тачпад / индикатор -->
        <TextView
            android:id="@+id/touchpad"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/touchpad_bg"
            android:gravity="center"
            android:text="@string/touchpad_hint"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            android:keepScreenOn="true" />

        <!-- Кнопки управления -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="3"
            android:useDefaultMargins="true">

            <Button
                android:id="@+id/leftClickButton"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:text="@string/left_click" />

            <Button
                android:id="@+id/rightClickButton"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:text="@string/right_click" />

            <Button
                android:id="@+id/recenterButton"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:text="@string/recenter" />

            <Button
                android:id="@+id/scrollUpButton"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:text="@string/scroll_up" />

            <Button
                android:id="@+id/backButton"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:text="@string/back" />

            <Button
                android:id="@+id/homeButton"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:text="@string/home" />

            <Button
                android:id="@+id/scrollDownButton"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:text="@string/scroll_down" />

            <Button
                android:id="@+id/settingsButton"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="wrap_content"
                android:text="@string/settings" />
        </GridLayout>

    </LinearLayout>
</ScrollView>
